''' calculate the height of a tree
1
/\
2 3 
'''
class node:
    def __init__(self, data):
        self.data = data
        self.left = None
        self.right = None
def height(root):
    if not root:
        return 0
    return 1+max(height(root.left), height(root.right))    
root = node(int(input("Enter root: ")))
root.left = node(int(input("Enter left: ")))
root.right = node(int(input("Enter right: ")))
root.left.right= node(int(input("Enter left-right: ")))
root.left.left= node(int(input("Enter left-left: ")))
root.right.left= node(int(input("Enter right-left: ")))
root.right.right= node(int(input("Enter right-right: ")))
print("Height of the tree is:", height(root))
