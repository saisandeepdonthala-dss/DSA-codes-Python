# Array oprations append delete insert update
arr =[10,20,30,40,50]
print("Length of array:",len(arr))
arr.append(90)
print("array after append: ", arr)
arr.insert(3,25)
print("array after insert: ", arr)
arr.remove(10)
print("array after deleting: ", arr)
arr.sort()
print("array after sorting: ", arr)
arr.sort(reverse=True)
print("array after sorting desending order:", arr)
arr.sort(reverse=False)
print("array after sorting asending order:", arr)
new_arr=sorted(arr)
print("new sorted array:", new_arr)
new_arr[5]=60
print("array after updating: ",new_array)
