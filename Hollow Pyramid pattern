#Reverse pyramid pattern
#Hollow Pyramid
n=int(input("enter size: "))
for i in range (0,n):  #rows
    for s in range (0, n-i-1):
        print (" ", end=" ")
    for j in range(0, 2*i+1):   #Colms
        if i==0 or i==n-1 or j==0 or j==2*i:
            print("*", end=" ")
        else:
            print(" ", end=" ")
    print()


